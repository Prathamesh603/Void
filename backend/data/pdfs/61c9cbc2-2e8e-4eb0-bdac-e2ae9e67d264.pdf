            <div class="cds--author-signature__author--details">
                <a href="https://www.ibm.com/think/author/cole-stryker.html">
                    
                    <span class="productive-heading-02">Cole Stryker</span>
                </a>
                <p class="auth-signature-paragraph body-short-02">Staff Editor, AI Models</p>
                <p class="auth-signature-paragraph body-short-02">IBM Think</p>
